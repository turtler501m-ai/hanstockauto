# KIS Open API
KISTOCK_APP_KEY=your_kis_app_key
KISTOCK_APP_SECRET=your_kis_app_secret
KISTOCK_ACCOUNT=1234567801

# Execution mode
TRADING_ENV=demo
DRY_RUN=true
ENABLE_LIVE_TRADING=false
REQUIRE_APPROVAL=true

# Trading parameters
SPLIT_N=7
STOP_LOSS_PCT=-15
TAKE_PROFIT=30
RSI_BUY=30
RSI_SELL=70
TOTAL_CAPITAL=10000000
MAX_POSITIONS=3
MAX_SINGLE_WEIGHT=0.30
CASH_BUFFER=0.20
MAX_DAILY_LOSS_PCT=3.0

# Notifications
SLACK_WEBHOOK_URL=
TRADE_DB_PATH=.runtime/trades.sqlite
