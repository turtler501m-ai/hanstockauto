`import pandas as pd
import yfinance as yf

WATCHLIST = ["005930", "000660", "035420", "035720", "005380", "207940", "068270", "051910"]

def _yf_ticker(code: str) -> str:
    return f"{code}.KS"

def _rsi(closes: pd.Series, period: int = 14) -> float:
    delta = closes.diff()
    gain = delta.clip(lower=0).rolling(period).mean()
    loss = -delta.clip(upper=0).rolling(period).mean()
    rs = gain / loss.replace(0, 1e-9)
    rsi = 100 - 100 / (1 + rs)
    return float(rsi.iloc[-1])

def find_candidates(min_score: int = 2) -> list[dict]:
    candidates = []
    for code in WATCHLIST:
        try:
            df = yf.download(_yf_ticker(code), period="3mo", progress=False)
            if df.empty or len(df) < 30: continue

            closes, volumes = df["Close"], df["Volume"]
            current = float(closes.iloc[-1])
            score, reasons = 0, []

            rsi = _rsi(closes)
            if 30 < rsi < 50:
                score += 1
                reasons.append(f"RSI {rsi:.0f}")

            ma5 = closes.rolling(5).mean().iloc[-1]
            ma5_yesterday = closes.rolling(5).mean().iloc[-2]
            if current > ma5 and closes.iloc[-2] <= ma5_yesterday:
                score += 1
                reasons.append("5일선 돌파")

            vol_avg = volumes.rolling(20).mean().iloc[-1]
            if volumes.iloc[-1] > vol_avg * 1.5:
                score += 1
                reasons.append("거래량 급증")

            if score >= min_score:
                candidates.append({"ticker": code, "current_price": current, "score": score, "reasons": reasons})
        except Exception as e: pass

    candidates.sort(key=lambda x: -x["score"])
    return candidates`

