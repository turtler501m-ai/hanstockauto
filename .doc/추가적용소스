`import math
import os
from typing import List, Dict

def build_orders(candidates: List[Dict], get_quote_fn) -> List[Dict]:
    capital = float(os.environ.get("TOTAL_CAPITAL", 10000000))
    cash_buffer = float(os.environ.get("CASH_BUFFER", 0.20))
    max_pos = int(os.environ.get("MAX_POSITIONS", 3))
    max_w = float(os.environ.get("MAX_SINGLE_WEIGHT", 0.30))

    deployable = capital * (1 - cash_buffer)
    per_position = deployable * max_w
    cost_multiplier = 1.001

    orders = []
    for c in candidates[:max_pos]:
        quote = get_quote_fn(c["ticker"])
        price = quote["ask1"] or quote["current"]
        if price <= 0: continue

        quantity = math.floor(per_position / (price * cost_multiplier))
        if quantity <= 0: continue

        orders.append({
            "ticker": c["ticker"], "side": "BUY", "quantity": quantity,
            "limit_price": int(price), "estimated_cost": quantity * price * cost_multiplier,
            "score": c["score"], "reasons": c["reasons"],
        })

    total_cost = sum(o["estimated_cost"] for o in orders)
    if total_cost > deployable:
        scale = deployable / total_cost
        for o in orders:
            o["quantity"] = math.floor(o["quantity"] * scale)
            o["estimated_cost"] = o["quantity"] * o["limit_price"] * cost_multiplier

    return [o for o in orders if o["quantity"] > 0]`

